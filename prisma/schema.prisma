generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  firstName     String
  middleName    String?
  lastName      String
  email         String   @unique
  phone         String
  whatsapp      String
  passwordHash  String
  gender        String
  state         String
  lga           String
  street        String
  buildingNo    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // A user can have multiple business registrations
  registrations BusinessRegistration[]
}

model BusinessRegistration {
  id              String   @id @default(cuid())
  userId          String
  proposedName    String
  businessType    String   // e.g., "Business Name", "LLC"
  status          String   @default("PENDING") // PENDING, PROCESSING, APPROVED, REJECTED
  similarityScore String?  // To store the result from the BN COMPLIANCE check
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String   @unique // Prevents race conditions: only 1 active OTP per email
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
