generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RegistrationStatus {
  UNSUBMITTED 
  PENDING
  QUERIED
  APPROVED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id            String   @id @default(cuid())
  role          Role     @default(USER)
  firstName     String
  middleName    String?
  lastName      String
  email         String   @unique
  phone         String
  whatsapp      String
  passwordHash  String
  gender        Gender
  state         String
  lga           String
  street        String
  buildingNo    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations BusinessRegistration[]
  wallet        Wallet?
}

model BusinessRegistration {
  id                String             @id @default(cuid())
  userId            String
  proposedName      String
  entityType        String             
  category          String             
  businessType      String?
  specificNature    String             
  status            RegistrationStatus @default(UNSUBMITTED) 
  similarityScore   String?

  // --- NEW: COMPANY INFORMATION ---
  companyEmail      String?
  companyState      String?
  companyCity       String?
  companyStreetNo   String?
  companyAddress    String?
  commencementDate  String?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  proprietors       Proprietor[]       // Relation to Proprietors
}

// --- NEW: PROPRIETOR MODEL ---
model Proprietor {
  id              String   @id @default(cuid())
  registrationId  String
  surname         String
  firstName       String
  otherName       String?
  email           String?
  phone           String
  gender          Gender
  dob             String
  state           String
  lga             String
  city            String
  streetNo        String?
  serviceAddress  String

  // Embedded Document Cloudinary URLs
  ninUrl          String?
  passportUrl     String?
  signatureUrl    String?

  registration    BusinessRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String   @unique 
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ==========================================
// FINANCIAL LEDGER SYSTEM
// ==========================================

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0.00) 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

// ==========================================
// SYSTEM SETTINGS & PRICING
// ==========================================

model ServicePricing {
  id          String   @id @default(cuid())
  serviceKey  String   @unique // e.g., "BUSINESS_NAME", "LLC", "NGO"
  title       String   // e.g., "Business Name Registration"
  price       Decimal  @default(0.00)
  
  updatedAt   DateTime @updatedAt
}
model Transaction {
  id            String            @id @default(cuid())
  walletId      String
  amount        Decimal
  balanceBefore Decimal           
  balanceAfter  Decimal           
  type          TransactionType   
  status        TransactionStatus @default(PENDING) 
  reference     String            @unique 
  description   String            
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  wallet        Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
}
