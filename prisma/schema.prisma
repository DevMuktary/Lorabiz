generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  USER
  STAFF
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RegistrationStatus {
  UNSUBMITTED 
  PENDING
  QUERIED
  APPROVED
  FAILED      // Added FAILED status for global tracking
}

enum TransactionType {
  CREDIT
  DEBIT
  REFUND
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum OfficerRole {
  DIRECTOR
  SECRETARY
  SHAREHOLDER
  PSC
}

enum TwoFactorMethod {
  EMAIL
  AUTHENTICATOR
}

// ==========================================
// MODELS
// ==========================================

model User {
  id              String           @id @default(cuid())
  role            Role             @default(USER)
  firstName       String
  middleName      String?
  lastName        String
  email           String           @unique
  phone           String           @unique
  whatsapp        String           @unique
  oldPhone        String?   // Tracks previous number in case of fraud
  phoneChangedAt  DateTime? // Tracks when they last changed it
  passwordHash    String
  gender          Gender
  state           String
  lga             String
  street          String
  buildingNo      String?
  ipAddress       String?          // Tracks registration IP
  
  // Two-Factor Authentication (MFA) Fields
  twoFactorEnabled Boolean         @default(false)
  twoFactorMethod  TwoFactorMethod?
  twoFactorSecret  String?         // Stores encrypted Base32 TOTP secret for Google Authenticator
  
  isSuspended   Boolean   @default(false) // Allows MD to lock out malicious users
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  registrations    BusinessRegistration[]
  llcRegistrations LlcRegistration[]
  ninRequests      NinRequestLog[]
  notifications    InAppNotification[]
  wallet           Wallet?
  waitlists        Waitlist[]
  twoFactorCodes   TwoFactorCode[]
  staffActions     StaffActionLog[]
  promoUsages      PromoUsage[]
  
  // --- STAFF ASSIGNMENTS ---
  assignedBiz      BusinessRegistration[] @relation("BizStaffAssignment")
  assignedLlcs     LlcRegistration[]      @relation("LlcStaffAssignment")
}

// ==========================================
// BUSINESS NAME REGISTRATION
// ==========================================

model BusinessRegistration {
  id                String             @id @default(cuid())
  trackingId        String?            @unique // Short numeric ID (e.g., "482910")
  userId            String
  proposedName      String
  altName1          String?
  altName2          String?
  ownershipType     String?
  entityType        String             
  category          String             
  businessType      String?
  specificNature    String             
  status            RegistrationStatus @default(UNSUBMITTED) 
  similarityScore   String?
  queryReason       String?            @db.Text
  queryStatus       String?            @default("UNRESOLVED")
  queryDate         DateTime?
  registrationNumber String?    // BN Number
  taxId              String?    // TIN
  certificateUrl     String?    // PDF URL
  statusReportUrl    String?    // PDF URL
  
  // --- COMPANY INFORMATION ---
  companyEmail      String?
  companyState      String?
  companyCity       String?
  companyStreetNo   String?
  companyAddress    String?
  commencementDate  String?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  processedAt       DateTime?          // Used for Staff TAT (Turnaround Time) tracking
  
  // --- STAFF ASSIGNMENT ---
  assignedToId      String?
  assignedStaff     User?              @relation("BizStaffAssignment", fields: [assignedToId], references: [id])

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  proprietors       Proprietor[]      
}

model Proprietor {
  id             String               @id @default(cuid())
  registrationId String
  surname        String
  firstName      String
  otherName      String?
  email          String?
  phoneCode      String               @default("+234") 
  phone          String
  gender         Gender
  dob            String
  state          String
  lga            String
  city           String
  streetNo       String?
  serviceAddress String

  // Embedded Document Cloudinary URLs
  ninUrl         String?
  passportUrl    String?
  signatureUrl   String?
  
  registration   BusinessRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

// ==========================================
// LLC / COMPANY REGISTRATION
// ==========================================

model LlcRegistration {
  id                  String             @id @default(cuid())
  trackingId          String?            @unique // Short numeric ID (e.g., "839201")
  userId              String
  status              RegistrationStatus @default(UNSUBMITTED)
  currentStep         Int                @default(1)
  
  proposedName        String             
  altName1            String?            
  altName2            String?            
  similarityScore     String?            
  email               String?
  principalActivity   String?
  specificActivity    String?
  description         String?            @db.Text
  
  registeredAddress   Json?      
  headOfficeAddress   Json?      
  
  useDefaultArticles  Boolean            @default(true)
  customArticles      Json?
  witnessDetails      Json?              
  memorandumObjects   String[]           
  
  companyType         String?            
  totalShareCapital   Float?
  shareClasses        Json?              

  declarantDetails    Json?
  
  queryReason         String?            @db.Text
  queryStatus         String?            @default("UNRESOLVED")
  registrationNumber String?    // RC Number
  taxId              String?    // TIN
  certificateUrl     String?    // PDF URL
  statusReportUrl    String?    // PDF URL
  memorandumUrl      String?    // PDF URL (LLC Only)

  witnessSignatureUrl   String?
  declarantSignatureUrl String?
  reasonRestrictionUrl  String?
  otherDocumentsUrl     String?
  
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  processedAt         DateTime?          // Used for Staff TAT (Turnaround Time) tracking
  
  // --- STAFF ASSIGNMENT ---
  assignedToId        String?
  assignedStaff       User?              @relation("LlcStaffAssignment", fields: [assignedToId], references: [id])
  
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  officers            CompanyOfficer[]
}

model CompanyOfficer {
  id                 String          @id @default(cuid())
  registrationId     String
  
  roles              OfficerRole[] 
  
  surname            String
  firstName          String
  otherName          String?
  dob                String
  gender             String
  nationality        String
  formerName         String?
  formerNationality  String?
  occupation         String
  phone              String
  email              String
  
  idType             String?
  idNumber           String?
  taxResidency       String?
  tin                String?
  
  residentialAddress Json?
  serviceAddress     Json?
  
  sharesAllotted     Float?    
  pscDetails         Json?     
  
  idDocumentUrl      String?
  signatureUrl       String?
  
  registration       LlcRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

// ==========================================
// NIMC / NIN SLIP SERVICES
// ==========================================

model NinSlipPricing {
  id          String   @id @default(cuid())
  slipType    String   @unique // "nin_regular", "nin_standard", "nin_premium"
  displayName String   // "Regular Slip", "Standard Slip", "Premium Card Slip"
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model NinRequestLog {
  id            String   @id @default(cuid())
  userId        String
  ninMasked     String   // Storing masked NIN (e.g., "********123") for privacy & audit
  slipType      String
  amountCharged Decimal  @db.Decimal(10, 2)
  status        String   // "SUCCESS" | "FAILED"
  reference     String   @unique // Links to Wallet Transaction reference
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// SYSTEM AUTH, NOTIFICATIONS, LEDGER & WAITLIST
// ==========================================

model InAppNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // "info" | "success" | "warning"
  link      String?  // Deep link (e.g., "/dashboard/cac/register/view/123")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String   @unique 
  code      String
  resendCount         Int       @default(0)
  nextResendAllowedAt DateTime?
  lockedUntil         DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Wallet {
  id          String        @id @default(cuid())
  userId      String        @unique
  balance     Decimal       @default(0.00) 
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model ServicePricing {
  id             String   @id @default(cuid())
  serviceKey     String   @unique 
  title          String   
  price          Decimal  @default(0.00)
  isActive       Boolean  @default(true) // MDS Kill Switch
  maintenanceMsg String?  // Custom banner text e.g., "CAC Portal is down"
  updatedAt      DateTime @updatedAt
}

model Transaction {
  id            String            @id @default(cuid())
  walletId      String
  amount        Decimal
  balanceBefore Decimal            
  balanceAfter  Decimal            
  type          TransactionType    
  status        TransactionStatus  @default(PENDING) 
  reference     String             @unique 
  description   String             
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  wallet        Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Waitlist {
  id        String   @id @default(cuid())
  userId    String
  service   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service])
}

// ==========================================
// TWO-FACTOR AUTHENTICATION & SECURITY AUDIT TRAILS
// ==========================================

model TwoFactorCode {
  id        String   @id @default(cuid())
  userId    String
  code      String   // Hashed 6-digit verification code
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StaffActionLog {
  id          String   @id @default(cuid())
  userId      String   // ID of the Staff or MD performing the action
  action      String   // e.g., "QUERIED_CAC_APPLICATION", "APPROVED_LLC", "UPDATED_PRICING"
  targetId    String?  // ID of the affected registration, wallet, or user
  details     String?  // JSON string or summary of exact changes made
  ipAddress   String?  // Client IP address
  userAgent   String?  // Browser/Device string
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SecurityAuditLog {
  id          String   @id @default(cuid())
  email       String   // Attempted email address
  role        String?  // User role if account exists (ADMIN, STAFF, USER)
  event       String   // LOGIN_SUCCESS, LOGIN_FAILED, BRUTE_FORCE_LOCKOUT, UNAUTHORIZED_PORTAL_ACCESS
  ipAddress   String?  // Client IP address
  userAgent   String?  // Device / Browser string
  details     String?  // Failure reason or success metadata
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([event])
  @@index([createdAt])
}

model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  discountPct   Float?       
  fixedAmount   Decimal?     
  usageLimit    Int?         // Total available for ALL users globally
  restrictedServices String[] // e.g., ["LLC", "BUSINESS_NAME"] or ["ALL"]
  perUserLimit  Int          @default(1) // Max times a SINGLE user can use it
  timesUsed     Int          @default(0)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now()) // Added so chronological sorting works perfectly

  usages        PromoUsage[] // Tracks who used it
}

// NEW TABLE: The Redemption Ledger
model PromoUsage {
  id          String    @id @default(cuid())
  promoId     String
  userId      String
  usedAt      DateTime  @default(now())

  promo       PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([promoId])
  @@index([userId])
}

model BlockedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?  // e.g., "Spam registration"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalSetting {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "SUPPORT_WHATSAPP"
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
