generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  firstName     String
  middleName    String?
  lastName      String
  email         String   @unique
  phone         String
  whatsapp      String
  passwordHash  String
  gender        String
  state         String
  lga           String
  street        String
  buildingNo    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations BusinessRegistration[]
  wallet        Wallet?  // NEW: 1-to-1 connection to the user's wallet
}

model BusinessRegistration {
  id              String   @id @default(cuid())
  userId          String
  proposedName    String
  businessType    String   
  status          String   @default("PENDING") 
  similarityScore String?  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String   @unique 
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// --- NEW FINANCIAL LEDGER SYSTEM ---

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0.00) // Stored as a float to handle Kobo if necessary
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  amount      Float
  type        String   // "CREDIT" (Funding) or "DEBIT" (Payment for services)
  status      String   @default("PENDING") // "PENDING", "SUCCESS", "FAILED"
  reference   String   @unique // To store Paystack/Flutterwave transaction references
  description String   // e.g., "Wallet Funding via Paystack" or "Payment for BN Registration"
  createdAt   DateTime @default(now())

  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}
